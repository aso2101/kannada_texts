    <body>
      <head>aparājitēśvara śataka</head>
      <label>utpalamāle/caṁpakamāle</label>
      <lg n="1">
	<l>śrīkulamāptagōtramamalāṁgamataṁdrate samyagāyu vi</l>
	<l>dyākuśalatvamādoḍamidennadidanyamenutte kaṁḍu ni</l>
	<l>rvyākulanāgi yellarinagaldu maṇitrayasaṁpadakke ra</l>
	<l>tnākaranādavaṁ tava kr̥pātmanalā! aparājitēśvarā!</l>
      </lg>
      <lg n="2">
	<l>naṁbuvudēḷu tattvamanaduttamadr̥ṣṭi tadarthamaṁ nayā</l>
	<l>rthaṁ bare nōḍi bhēdipudaduttamabōdhamahiṁseyalli mā</l>
	<l>rga0 biḍadirpuduttamacaritramiviṁtu maṇitrayaṁ tadī</l>
	<l>yāṁbudhi yāvuduttamatapaṁgaḷalā! aparājitēśvarā!</l>
      </lg>
      <lg n="3">
	<l>mūjagaveṁba gēhadoḷe tuṁbida vastugaḷāru kāyavai</l>
	<l>dōjeya tattvavēḷu navabhēdapadārthamivaṁ tapasvi saṁ</l>
	<l>yōjisi kūḍekūḍe paribhāvisi tannane kāṇbudarke cē</l>
	<l>tōjayanāgabēku modaleṁdeyalā! aparājītēśvarā!</l>
      </lg>
      <lg n="4">
	<l>baḷikaṇupekke panneraḍaralli catuṣkada dammajānadoḷ</l>
	<l>suḷisuḷidāḍi kūḍe gurupaṁcakadoḷpoḷedāḍi cittada</l>
	<l>ggaḷamanaḍaṁgisuttoḍane tannaya dēhadoḷātmanalli niṁ</l>
	<l>daḷalaḷidirdavaṁ tava kr̥pātmanalā! aparājitēśvarā!</l>
      </lg>
      <lg n="5">
	<l>ā padadoḷ kṣaṇakṣaṇake karmasamūhake hāni sadguṇō</l>
	<l>dīpikeyappudōdina pariśramamuṁ tapadubbeyuṁ sudhā</l>
	<l>rūpamaneydutirkumadariṁdadanē sakala prayatnadiṁ</l>
	<l>sthāpisi muktiyaṁ paḍevudeṁdeyalā! aparājitēśvarā!</l>
      </lg>
      
      <lg n="6">
	<l>adu laghukarmigātmatanubhēdavicāradoḷaḷtiyuḷḷavaṁ</l>
	<l>gudayipudalladē sakalaśāstramanōdidoḍaṁ tapaṁgaḷo</l>
	<l>ḷḷudidoḍamāgadaṁtadarinā ruciyuḷḷavanē bhavatprasā</l>
	<l>dada sukhayeṁdu mecci parikīrtipenānaparājitēśvarā!</l>
      </lg>
      <lg n="7">
	<l>bhēda vicārameṁto tanumūravaralliye karmaveṁṭivē!</l>
	<l>vēdanegiṁbugaḷkaḍegacētanarūpigaḷātmanilli mi</l>
	<l>trōdayanāgi bāḷdapanavaṁ sukhi cinmayaneṁdu buddhiyiṁ</l>
	<l>bhēdisi bērugeydoḷage nōḷpudalā! aparājitēśvarā!</l>
      </lg>
      <lg n="8">
	<l>poragidu dhāturūpadoḍalinneraḍuṁṭoḷagoṁdu tējadiṁ</l>
	<l>turugida taijasāṁgamoḍanaṣṭamalā śritakārmaṇāṁgamoṁ</l>
	<l>dure pesariṁde bērpaḍisabarpudu rūpade miśritaṁgaḷī</l>
	<l>seremane mūraroḷpudidanātmanahō! aparājitēśvarā!</l>
      </lg>
      <lg n="9">
	<l>āguta pōgutirpudidu bāhyaśarīramanēkarūpadiṁ</l>
	<l>yōgaviyōgiyappa padinālku guṇasthalakālakallade</l>
	<l>pōgadu taijasaṁ pudida kārmaṇamuṁ sale bhēdabhāvanō</l>
	<l>dyōgamaniṁdutoṭṭasagavēḷkumadarkaparājitēśvarā!</l>
      </lg>
      <lg n="10">
	<l>kaḷedu samastabāhyaratiyaṁ manadutsavadiṁde gūḍhasu</l>
	<l>sthaḷadoḷagirdu tannoḷage tannaya rūpane nimma rūpinā</l>
	<l>paḷukina boṁbeyaṁdavenutuṁ nenedīkṣisuvaṁge cittadoḷ</l>
	<l>poḷeyade māṇbudē paramasiddhana rūpaparājitēśvarā!</l>
      </lg>
      <lg n="11">
	<l>tanu jinagēhaveṁbudoḷagirdu nijātmane dēvaneṁbudā</l>
	<l>tanuparimāṇaneṁbuda śarīrakaneṁbudu bōdhadarśanaṁ</l>
	<l>tanuvenisirdaneṁbudakalaṁkanabādhanakhaṁḍaneṁba bhā</l>
	<l>vaneyane bhāvisuttire bhavacyuti tānaparājitēśvarā!</l>
      </lg>
      <lg n="12">
	<l>moda modalāsarappudoḍanoppire saṁtavappudaṁtu mā</l>
	<l>ṇade paribhāvisuttire mahāsukhamappudu bāhyadāṭadoḷ</l>
	<l>bedarikeyappudātmanoḷe meccugeyappudu lōkamella mā</l>
	<l>yada maruḷāgi tōrpudu nijātmarataṁgaparājitēśvarā!</l>
      </lg>
      <lg n="13">
	<l>nuḍi kiridappudūṭadoḷarōcakamappudu bāhyagōṣṭhiyoḷ!</l>
	<l>siḍimiḍiyappudaṁte bahiraṁgada nōṭake kaṇgoḷollavā</l>
	<l>kaḍupina kālgaḷāṭavaḍakakkoḷagappudu buddhi muktiyaṁ</l>
	<l>tuḍukutamirpudalte paramātmarataṁgaparājitēśvarā!</l>
      </lg>
      <lg n="14">
	<l>porage tapaṁgaḷārara sahāyate bēku śarīra mōhamaṁ</l>
	<l>toreyale bēku bhāvaneya śāstra vilōkite bēku niccaluṁ</l>
	<l>nereva virakti bēku ripubaṁdhugaḷoḷsarigāṇabēku ka</l>
	<l>ṇṇaridu nijātmanaṁ calisadīkṣisuvaṁgaparājitēśvarā!</l>
      </lg>
      <lg n="15">
	<l>meyyoḷagennegaṁ mamateyaṁṭavananne gamugra kālanā</l>
	<l>keyyoḷagirda pakki viṣayaṁgaḷa meccidavaṁ viṣāgniyoḷ</l>
	<l>cuyyane beṁdavaṁ bahukaṣāyamanotti kaḷaljadātana</l>
	<l>yyayyo!muḷuṁgidaṁ narakadoḷpalavēnaparājitēśvarā!</l>
      </lg>
      <lg n="16">
	<l>tanupageyeṁbavaṁ vratayutaṁ viṣayaṁ viṣaveṁdu biṭṭavaṁ</l>
	<l>vinutatapasvi kōpaviḍidirda kaṣāyake dūranāda śāṁ</l>
	<l>tane sakalātmarakṣakaninituṁ guṇasaṁtatigūḍi tattva bhā</l>
	<l>vaneyoḷe bāḷvanē śivanavaṁgeṇeyāraparājitēśvarā!</l>
      </lg>
      <lg n="17">
	<l>uṁbanitarke koṭṭu pageyoḷpavuṁ teradiṁde sēveyaṁ</l>
	<l>koṁba vivēkiyaṁte virasānnamanē tanuviṁge jōkeyiṁ</l>
	<l>tuṁbi japaṁ tapaṁ paramaśāstra rahasyadoḷātma kāryamaṁ</l>
	<l>beṁbiḍadāvagaṁ negaḷvavaṁgeṇeyāraparājitēśvarā!</l>
      </lg>
      <lg n="18">
	<l>uṁbudu nīrasaṁ porevudoṁdoḍalirpudu gūḍhavāsavā</l>
	<l>ḍuṁbolanēḷutattva moḷuvātu sarasvatiyoḷniraṁtaraṁ</l>
	<l>haṁbalaghapraṇāśadoḷagīkṣaṇamātmanoḷāgi bāḷvadhī</l>
	<l>raṁ bahukarmamaṁ kṣaṇake khaṁḍisanē! aparājitēśvarā!</l>
      </lg>
      <lg n="19">
	<l>tannoḷe tanna nōḷpa r̥ṣiganyara nōṭamadēke cidguṇō</l>
	<l>tpanna sudhānnamuṇba munigoḷḷuṇiseṁba vivakṣeyēke si</l>
	<l>ddhaṁ nama eṁba vākyamire bērnuḍiyēke nijātmarūpadoḷ</l>
	<l>ninnoḍanāḍuvaṁguḷida gōṣṭhigaḷēkaparājitēśvarā!</l>
      </lg>
      <lg n="20">
	<l>biḍade kaṣāyamaṁ suḍade yiṁdriyatr̥ṣṇegaḷaṁ parīṣaha</l>
	<l>kkoḍanidirāgi gellade suguptigaḷu pugadātmanaṁ malaṁ</l>
	<l>biḍidoḍaliṁde bērpaḍisi nōḍade summane karmaśatruvē</l>
	<l>biḍu biḍu pōgenalnuḍige pōdapudē! aparājitēśvarā !</l>
      </lg>
      <lg n="21">
	<l>puruparamēśanādiyene tīrthakararmodalāgi kānanāṁ</l>
	<l>taradoḷagadriyoḷ caḷiyoḷātapadoḷmaḷeyoḷ kṣudhātr̥ṣā</l>
	<l>bharamanaḍartu gellade jinēśvararādare kōḍi bāḍi jō</l>
	<l>karipenagetta nirjareya mātu jaḍaṁgaparājitēśvarā!</l>
      </lg>
      <lg n="22">
	<l>ōdida tattva milla paridiṭṭa parigrahamilla taggitaṁ</l>
	<l>pāda kaṣāyamilla nere gella parīṣahamilla sadguṇā</l>
	<l>mōdateyilla māḍiduru dharmavikāsateyilla nimmoḷa</l>
	<l>tyādarabhaktiyilla sukhiyāguveneṁtaparājitēśvarā!</l>
      </lg>
      <lg n="23">
	<l>bōdhipeneṁbellarumanāgamapaddhati bāradāytu ba</l>
	<l>lṭādheyanāṁtu sairisutamātmanoḷirda malīmasaṁgaḷaṁ</l>
	<l>sōdipeneṁbenaḷḷedetanaṁ biḍadāytu nijātma dr̥ṣṭiyiṁ</l>
	<l>sādhipeneṁbenoṁdoḍe manaṁ caḷamāytaparājitēśvarā</l>
      </lg>
      <lg n="24">
	<l>bhūrimataṁgaḷaṁ tiḷivuduṁ palaraṁ matidōri dharmadoḷ</l>
	<l>sēripuduṁ mahōgratapadoḷpaṭuvappudumātmanaṁ manō</l>
	<l>rāgoḷīkṣisutte bhavabaṁdhamanikkuva buddi summane</l>
	<l>bāradadarke nimma karuṇōnnatibēkaparājitēśvarā!</l>
      </lg>
      <lg n="25">
	<l>kuḍuva samartharārakhaḷalōkake nīṁ poragāgi mānavaṁ</l>
	<l>paḍeva padaṁgaḷāvuvu tapaṁ śrutamuṁ poragāgi ballavaṁ</l>
	<l>piḍiva suvastuvāvudu maṇitritayaṁ poragāgi sōlu ka</l>
	<l>ṇṇiḍuveḍeyāvudātmavibhavaṁ poragāgaparājitēśvarā!</l>
      </lg>
      <lg n="26">
	<l>puṭaviḍuvalli kiccinurigaṁjidoḍā kanakakke kūḍidā</l>
	<l>kuṭilate pōkumē malakalaṁkamanūdi kaḷalji kāṁtisaṁ</l>
	<l>puṭadoḷagātmanaṁ nilisi nirmalanāguveneṁba bhavyanu</l>
	<l>tkaṭatapadubbegaḷkidoḍe siddhipudē! aparājitēśvarā !</l>
      </lg>
      
      <lg n="27">
	<l>rāgake rōṣakāgi lalanādiviyōgadoḷugrayuddhadoḷ</l>
	<l>nīgidenaṁgakōṭigaḷanaṁtadariṁ bhavarōgiyādenā</l>
	<l>rōgada mūlamaṁ suḍuva ghōratapaṁdaḷedoṁdukāyamaṁ</l>
	<l>tyāgisalaṁjutirdapenalā dhr̥tidōraparājitēśvarā!</l>
      </lg>
      
      <lg n="28">
	<l>pōgade pōda pōda bhavakōṭigaḷoḷmaḷisaṁdu koṁdu tāṁ</l>
	<l>kūguva mōharākṣasananugratapōbharadhīranāgi nāṁ</l>
	<l>tāguveneṁdu taḷtiridu gelvenadeṁdu jagakke mitranā</l>
	<l>nāguveneṁdu ninneḍeyaneyduveneṁdaparājitēśvarā!</l>
      </lg>
      <lg n="29">
	<l>hēvaramaṁ kṣaṇāṁtarake tōrpa sukhakkolaviṁdo nāḷeyō</l>
	<l>sāva janaṁgaḷoḷmamate matsaravīgaḷo baigināgaḷō</l>
	<l>bēva śarīradoḷbardukuvāse viraktiyoḷātmatattvamaṁ</l>
	<l>bhāvisi mukta nāgalaridāytukaṭā! aparājitēśvarā!</l>
      </lg>
      <lg n="30">
	<l>rōgigapathyamē ruciyenippudu vaidyame kaipeyādoḍā</l>
	<l>rōgavināśakāvudu hitaṁ manujaṁgadaraṁte bhōgamē</l>
	<l>rājisutirkumādoḍamadaṁ kaḍegotti tapōvratāgamō</l>
	<l>dyōgadoḷāḍadirdoḍavanēṁ kiḍanē! aparājitēśvarā!</l>
      </lg>
      <lg n="31">
	<l>nāganarāmarēṁdrara sukhaṁ siriyuṁ nijadiṁde bhāvisal</l>
	<l>jōgimahēṁdrajālada kumaṁtrade tōrida māmaraṁgaḷoḷ</l>
	<l>tūguva paṇgaḷaṁ savideneṁbana saṁbhramadaṁte karmasaṁ</l>
	<l>yōgadināytu pōytenisuguṁ piridēnaparājitēśvarā!</l>
      </lg>
      <lg n="32">
	<l>muktiyoḷalladilla sukhavaṁtadu karmavināśavillade</l>
	<l>vyaktige bāradā duritanāśake dīkṣeye bēku mōhadā</l>
	<l>śaktiyoḷirdavaṁge rucidōradu dīkṣeyadarke nimma sa</l>
	<l>dbhaktiye bījamoyyanadanīvudu muṁdaparājitēśvarā!</l>
      </lg>
      <lg n="33">
	<l>śaktige takka dāna gurupūjana suvrata parvakālani</l>
	<l>rbhuktigaḷaṁ negaḷcute jināgamagōṣṭhigaḷalli dharmasaṁ</l>
	<l>yuktara mēḷadoḷ kaḷeyutuṁ dinamaṁ naḍevaṁge mōhadā</l>
	<l>śakti saḍildu pōpudidu bhaktiyalā! aparājitēśvarā!</l>
      </lg>
      <lg n="34">
	<l>māḍuvudarke śakti tanagoccatamilladoḍoldu dharmamaṁ</l>
	<l>māḍuvarilli nōḍi pariṇāmavaneyduvudorme nōḷpuduṁ</l>
	<l>kūḍadoḍaṁte kēḷu sukhiyappudu nimmane naṁbi dharmamaṁ</l>
	<l>jōḍisikoṁbudarke birisuṁṭe! janakkaparājitēśvarā!</l>
      </lg>
      <lg n="35">
	<l>havaṇisi koṁbudoyyane parigrahamaṁ gatinālkaraṁdamaṁ</l>
	<l>śivapadadaṁdamaṁ tiḷiyutirpudu kāyada kaṣṭamaṁ nijā</l>
	<l>tmavipulaśuddhiyaṁ neneyutirpudu kūḍe virakti tāne saṁ</l>
	<l>bhavipudu dēhigeṁdorevudōjeyalā! aparājitēśvarā!</l>
      </lg>
      <lg n="36">
	<l>mikka parigrahagrahitananyarinādupadēśalēśamaṁ</l>
	<l>lekkipanē virōdhigaḷa ballane mellerdeyuṁṭe mattavaṁ</l>
	<l>nakkudu nakkudē muniduduṁ munisē avanāṭadellavuṁ</l>
	<l>makkaḷa mēḷa dāṭavolirpudalā! aparājitēśvarā!</l>
      </lg>
      <lg n="37">
	<l>grahaveḍegoṁḍavaṁge maravorme vivēkavadorme kūḍe saṁ</l>
	<l>grahisutamirkumallade yathāsthitiyuṁṭe niraṁtaraṁ pari</l>
	<l>gradoḷagirdavaṁge nuḍiyuṁ naḍeyuṁ kṣaṇikaṁgaḷalladē</l>
	<l>sahaja caritradoḷniruge yettaṇa mātaparājēśvarā!</l>
      </lg>
      <lg n="38">
	<l>sorki śarīra nāridhanavennaviveṁdavaralli kaṇmanaṁ</l>
	<l>sirkivivēkigaḷnuḍida dharmamanollade kūḷa korbinoḷ</l>
	<l>karkaśavr̥ttiyoḷnaḍeva kāmukaraṁtakanoyva kāladoḷ</l>
	<l>markaṭanaṁte palgirivarētara bāyaparājitēśvarā!</l>
      </lg>
      <lg n="39">
	<l>racceya saṁbhramakke kuṇidiccheya kūḷuṇutaṁ kṣaṇāṁtadoḷ</l>
	<l>kiccina koṁḍamaṁ puguva raṁḍeyavolviṣayaṁgaḷiccheyaṁ</l>
	<l>mecci manakke baṁda teradoḷnaḍedollade suvrataṁgaḷaṁ</l>
	<l>huccaro durgatisthaḷake bīḷvaradēkaparājitēśvarā!</l>
      </lg>
      <lg n="40">
	<l>piṁdaṇa janma janmadoḷagellidanī bhavadatta tannanā</l>
	<l>rtaṁdaradella muṁde tanaginneḍe puṭṭida tāṇatāṇadoḷ</l>
	<l>kuṁdadupārjisirda dhanamaṁ tanumaṁ barutoṁdanuṁ manaṁ</l>
	<l>taṁdude nimma naccirade ciṁtipudēkaparājitēśvarā!</l>
      </lg>
      
      <lg n="41">
