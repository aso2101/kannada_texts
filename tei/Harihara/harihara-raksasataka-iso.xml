    <body>
      <head>rakṣāśatakaṁ</head>
      <label>sragdhare mattu mahāsragdhare</label>
      <lg n="1">
	<l>śrīmad‌gaṁgātaraṁgāvr̥tavimalajaṭājūṭa sarvēśa gaurī</l>
	<l>vāmāṁgāliṁganāliṁgita ghanamahimōdāracāritra caṁcat</l>
	<l>sōmārdhōttaṁsa saṁsārajaladhivaḍabākārasākāra bhakti</l>
	<l>prēmāṁbhōrāśi paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="2">
	<l>tirugutteṁbattu nālkuṁ daśaśataśatajanmaṁgaḷoḷ‌ puṭṭi nimmoṁ</l>
	<l>diravaṁtiṁteṁtuṭeṁdēnumanaṟiyade maṇṇāgi kallāgutuṁ du</l>
	<l>rdharagulmaṁ bhūribhūjaṁ puḷu khaga-mr̥gavāguttumeṁtakke baṁdeṁ</l>
	<l>narajanmakkayya paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      
      <lg n="3">
	<l>basiṟoḷ māsotti nettar pasarisi karuḷiṁ sutti mūtraṁ purīṣaṁ</l>
	<l>musukiṭṭellaṁgadoḷ kettiraludaraśikhijvāleyiṁdatta mittaṁ</l>
	<l>kusiyuttuṁ puṭṭuvoṁdujjugadoḷe maraṇāvastheyaṁ tāḷdibaṁdā</l>
	<l>yasamaṁ cittaysi paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="4">
	<l>ēneṁbeṁ bālyadoḷ mēlaṟiyade maladiṁ mūtradiṁ ślēṣmadiṁto</l>
	<l>ydānāreṁdēnumaṁ bhāvisade badhiranaṁtaṁdhanaṁtirdu mattaṁ</l>
	<l>nānābhōjyakke pakkāgute carisideninnāṟeninnāṟenayyō</l>
	<l>ānaṁdāṁbhōdhi paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      
      <lg n="5">
	<l>piridoṁdajñānadiṁ yauvanavikaḷate maidōṟe kāṁtānivāsāṁ</l>
	<l>taradoḷ śvānaṁge hīhaṁdige kapigeṇeyāgirdu bēḷāgutuṁ tat</l>
	<l>karaṇakkāḷāgi hāḷāgute baṟudoṟevōdeṁ baḷaldeṁ bigurteṁ</l>
	<l>maruḷādeṁ dēva paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="6">
	<l>strīmātraṁ nētradattal suḷidoḍe manavirbhāgamāgutte tāpa</l>
	<l>stōmaṁ kaimīṟi lajjārasamuḍugi vivēkaṁ kaḷaldōḍi rāgaṁ</l>
	<l>kaimikkānāvanēneṁdaṟiyada teṟanaṁ māḍutirdappudiṁtī</l>
	<l>kāmaṁ kāmāri paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="7">
	<l>ēpoḷtuṁ gātramaṁ śōṣisute karaṇamaṁ kaṁdisuttuṁ nirarthaṁ</l>
	<l>tāpavrātakke pakkāgisutamaḷaguṇastōmamaṁ khaṁḍisuttuṁ</l>
	<l>pāpaprāraṁbhakartr̥tvamanenagenisaṁ māḍutirdappudiṁtī</l>
	<l>kōpaṁ śāṁtātma paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="8">
	<l>dhanamaṁ strīputraraṁ kemmane kiḍuva gr̥hakṣētramaṁ mitraraṁ va</l>
	<l>stranikāyākalpamaṁ muṁtenagenute karaṁ kāṁkṣeyiṁ kūrmeyiṁde</l>
	<l>ḷḷanituṁ puṇyakke māḍal kuḍade kiḍisuvī lōbhamaṁ dāni nīṁ chē</l>
	<l>daneyaṁ māḍutte paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="9">
	<l>dēhōhaṁ eṁdu makkaḷ manedhanavaḷiyal kaṁdisutturbuvāśā</l>
	<l>vyūhakkiṁbāgisuttuṁ nenedu maṟugisuttuṁ musuṁkirda mithyā</l>
	<l>snēhāraṁbhānukūlaṁ nuḍigeḍeguḍadirdappudottaṁbadiṁdī</l>
	<l>mōhaṁ mōhāri paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="10">
	<l>adanēneṁbeṁ guṇavrātamane paṟiyutuṁ vidyeyaṁ khaṁḍisuttuṁ</l>
	<l>kadaḍuttuṁ cittamaṁ buddhiyanuṟadaṟeyaṭṭutte kāydappudennī</l>
	<l>madamātaṁgaṁ mahārōhaka nijacaraṇastaṁbhadoḷ kaṭṭi saiti</l>
	<l>ṭṭu dayāṁbhōrāśi paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="11">
	<l>pararaiśvaryakkasūyaṁgoḷute parara balpiṁge saṁtāpisuttuṁ</l>
	<l>parariṁdaṁ mikku bāḷal bayasi kudidu bēḷāgi beṁbīḷutirduṁ</l>
	<l>paraciṁtākṣōbheyiṁ matsaradoḍane karaṁ gāsiyādappenī ma</l>
	<l>tsaramaṁ targotti paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="12">
	<l>manavennaṁ durvikārakkeḷedapudu manaṁ mānamaṁ nurgidattī</l>
	<l>manavāśāvahniyoḷ‌ nūṁkidapudu manavī māyeyaṁ biṭṭu nimmaṁ</l>
	<l>neneyal‌ tānīyadayyō śivane bhavane kāruṇyavārāśiyennī</l>
	<l>manamaṁ saytiṭṭu paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="13">
	<l>pratyakṣaṁ sattu hōguttide naranikaraṁ tānidaṁ kaṁḍu kaṁḍuṁ</l>
	<l>nityatvaṁbetta pāṁgiṁ paḷiva muḷiva kāmippa kōpippa lōbhi</l>
	<l>ppatyaṁtaṁ garvipennī manake paramavairāgyamaṁ koṭṭu satyaṁ</l>
	<l>satyaṁ satyātma paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="14">
	<l>inituṁ vairāgyadattal neneyade madadattal mahāmōhadattal</l>
	<l>dhanadattal dhānyadattal satisutapitarattal sadā lōbhadattal ‌</l>
	<l>neneyuttirdappudennī manavidaneḍegoṁḍaḷkaṟiṁ dēva nīviṁ</l>
	<l>tenituṁ tīvirdu paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="15">
	<l>suvicārakkormeyuṁ sēradu naḍeyipudatyāgrahavyāptiyiṁ tā</l>
	<l>navicārakkeṁdoḍeṁṭaṁ nimirvudu bayalaṁ bhāvisuttirpudātmō</l>
	<l>dbhavamūlacchēdanōpāyavaneṇisadu mad‌buddhiyī buddhiyaṁśaṁ</l>
	<l>bhuve saṁtaṁ māḍi paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="16">
	<l>inituṁ tānalladāraṁ bageyadu madamaṁ garvamaṁ kūḍikoṁḍi</l>
	<l>rdenituṁ muṁgāṇadatyuddhatataramukhamāgirpudōraṁte vidva</l>
	<l>jjanamaṁ kaikoḷḷadennī manadoḍataṇahaṁkāraviṁtiṁtidaṁ dē</l>
	<l>vane nīṁ targotti paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="17">
	<l>dhanadoḷ dhānyaṁgaḷoḷ bhūṣaṇavitatigaḷoḷ putrasaṁtānadoḷ bhō</l>
	<l>ganikāyabhrāṁtiyoḷ kāṁteyara tanusukhacchāyeyoḷ māyeyoḷ‌ niṁ</l>
	<l>denasuṁ naṭṭirda maccittamanabhava nijāṁghridvayadhyānasānaṁ</l>
	<l>danivāsaṁ māḍi paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="18">
	<l>ōraṁtī dēhamaṁ rakṣisuvatibharadiṁduḷtu tettuṁ satēja</l>
	<l>kkārēnaṁ pēḷdoḍaṁ kaimugidu sugidu perbiṭṭiyaṁ pottu saṁsā</l>
	<l>rāraṁbhaṁgeydu duḥkhakkalasi maṟugi nimmaṁghriyaṁ pordideṁ sa</l>
	<l>tyāraṁbhaprēmi paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="19">
	<l>avicāraṁ mikku lābhaṁbaḍevatibharadiṁ sutti dēśaṁgaḷoḷ viṁ</l>
	<l>dhyavitānaprāṁtadoḷ tiṟaṟane tirugi modal‌geṭṭu beṁbiḷdu duḥkha</l>
	<l>vyavahārakkaḷki nimmī caraṇayugaḷamaṁ pordideṁ bhaktavr̥ṁdō</l>
	<l>tsavakalpōrvīja paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="20">
	<l>avaniṁtārādoḍaṁ palgiridu piridu bāyiṁde dainyākṣaraṁ saṁ</l>
	<l>bhavisuttennāḷda saṁdēśamane karuṇiseṁdalli martyaṁge sāvu</l>
	<l>ttave puṭṭuttirpa sēvānarakanadiyanīsāḍi mad‌bhāgyadiṁ ni</l>
	<l>nnavanādeṁ dēva paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="21">
	<l>tanuvaṁ strīputraraṁ rakṣipa vipuḷatekaikoṁḍu kārpaṇyavaktraṁ</l>
	<l>tanugātraṁ dīnanētraṁ tuṣalaghutaramātraṁ karaṁpordi tōrpiṁ</l>
	<l>janamaṁ bēḷpāseyiṁ sāvina pariyenipī dainyamaṁ biṭṭu nimmaṁ</l>
	<l>neneyuttirpaṁte paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="22">
	<l>maneyeṁduṁ makkaḷeṁduṁ jananijanakareṁduṁ vr̥thā patniyeṁduṁ</l>
	<l>dhanameṁduṁ dhānyameṁduṁ sakalaviṣayaviṁtennadeṁduṁ nirarthā</l>
	<l>rthanimittaṁ beṁdu tāpatrayadoḷe kudideṁ battideṁ bāḍideṁ yā</l>
	<l>tanegoṁḍeṁ dēva paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="23">
	<l>vipuḷānaṁgāgniyiṁ baṁdeḷeduravaṇipāśāgniyiṁdaṁ nirarthaṁ</l>
	<l>kupitōdbhūtāgniyiṁdaṁ harahara mige bēvuttu mirdappenānaṁ</l>
	<l>dapayōvārāśi nimmī vimaḷakarataḷābjaṁgaḷiṁdettutayyō</l>
	<l>kr̥peyiṁdaṁ nōḍi paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="24">
	<l>navedeṁ rōgaṁgaḷiṁdaṁ seḍedenanudinaṁ sēveyiṁdaṁ nirarthaṁ</l>
	<l>savedeṁ kāmaṁgaḷiṁdaṁ mige paribhavadoḷ baṁde nānāseyiṁdaṁ</l>
	<l>tavilādeṁ kōpadiṁdaḷkidenatimadadiṁ muṁdugeṭṭirdapeṁ śaṁ</l>
	<l>bhuve nīlagrīva paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="25">
	<l>ayyō saṁsārasaṁgakkaṟiyadeṟagideṁ maḷgideṁ māṟuvōdeṁ</l>
	<l>muyyāṁteṁ muṁdugeṭṭeṁ seḍedenuḍugideṁ māsideṁ sūsideṁ ki</l>
	<l>rgayyādeṁ kaṁdideṁ kuṁdidenalasidenāsattenallāḍideṁ nī</l>
	<l>nayyā kaikoṁḍu paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="26">
	<l>uragāsyālagna bhagnapracalitaharivol vyāghravaktraprayukta</l>
	<l>sphuritātaṁkāṁtaraṁgasthitamr̥gaśiśuvol siṁhahastāvalaṁba</l>
	<l>dviradaṁbōlirdenī māyeya mukhadeḍeyoḷ bēgadiṁ piṁgisāmad</l>
	<l>guruvē mat‌svāmi paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="27">
	<l>lalanāsaṁbhōgarōgaṁ pasivanuḍugisuttārtiyaṁ poṁgisuttuṁ</l>
	<l>balamaṁ kaiguṁdisuttuṁ sujanavacanapathyakke tāṁ vakrisuttuṁ</l>
	<l>sale lajjābhāvamaṁ mīṟisutumideyidakkauṣadhaṁgoṭṭu taṁdē</l>
	<l>taleyoḷ kaiyiṭṭu paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="28">
	<l>dviradaṁ matsyaṁ pataṁgaṁ bhramaranahiyenippiṁtivēkiṁdriyārthaṁ</l>
	<l>tiruguttirdappuviṁtī jananada baḷiyoḷ dēva paṁcēṁdriyārthaṁ</l>
	<l>virasaṁ vidrūpi mūrkhaṁ viṣayavikaḷanēnappeneṁtirpenayyō</l>
	<l>karuṇī kaikoṁḍu paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="29">
	<l>taradiṁ rōgaṁ viṣaṁ vr̥ścikavanalanahivyāghramugrāyudhaṁgaḷ</l>
	<l>duritaṁ matta dvipaṁ mūrkhatepoḍeva siḍil durjanaṁ durmadaṁ ta</l>
	<l>skarareṁbī kaṁṭakastōmada naḍuvoḍalirpaṁdamēṁ sōjigaṁ śaṁ</l>
	<l>kara nīṁ kaikoṁḍu paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="30">
	<l>dhanamaṁ saitārjipeṁ baitiḍuvenadaṟoḷaṁ puṇyavaivāhamaṁ mā</l>
	<l>ḷpenadaṁ putrargalaṁkāramanodavisuveṁ kūḍi bhōgippeneṁdāṁ</l>
	<l>neneyuttirpannegaṁ toṭṭane maraṇamadāgalke bēḷappa duściṁ</l>
	<l>taneyaṁ targotti paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="31">
	<l>kanakaṁ nīrakkaraṁ peṁḍiti kanasu sutar maṁju tāytaṁde vāyaṁ</l>
	<l>tanuvabhracchāye mitrar gaganakusumamiṣṭar marīcījalaṁ yau</l>
	<l>vanadharmaṁ mēghacāpaṁ gr̥havaciravenippiṁtivaṁ biṭṭu nimmaṁ</l>
	<l>neneyuttirpaṁte paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="32">
	<l>eravī dēhaṁ hiraṇyaṁ pudu sati pageyātmēṣṭaraupādhikar sō</l>
	<l>dararellaṁ vairigaḷ tāvenisidanaṟiduṁ matta māvarthadiṁdaṁ</l>
	<l>poreveṁ rakṣippenolveṁ biḍade naḍeyipeṁ naṁbi naccirpenenniṁ</l>
	<l>maruḷārārāne paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="33">
	<l>jalamaṁ pordirpa śaivālada teṟade karaṁ dīpikācchāyeyeṁtu</l>
	<l>jjvalavāṁtā caṁdralakṣaṁ mukuradoḷage tōrpā praticchāyeyeṁtaṁ</l>
	<l>taleyuttuṁ patti bennaṁ biḍadide ghanasaṁsāravī māyeyaṁ ni</l>
	<l>rmala nīnē tīrci paṁpāpuradarasa virūpākṣa rakṣippudenna0</l>
      </lg>
      <lg n="34">
	<l>neḷaloḷ pōrvaṁtirākāśamanavayavadiṁdīsuvaṁturviyaṁ tāṁ</l>
	<l>toḷevaṁtabhrāḷiyaṁ kaṁḍarisuva teṟadiṁ dhūmamaṁ sīḷva pāṁgiṁ</l>
	<l>baḷaluttirdappenī māyeya maneya duvāḷiṁde nirmāya nityō</l>
	<l>jjvaḷa nistraiguṇya paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="35">
	<l>madadiṁdaṁ poḷtu pōguttide śivaśiva mātsaryadiṁ poḷtu pōgu</l>
	<l>ttide āhā poḷtu pōguttide musukidatat‌kāmadiṁ poḷtu pōgu</l>
	<l>ttide lōbhavyāptiyiṁ kōpadinaṟiyade durmōhadiṁ poḷtupōgu</l>
	<l>ttide taṁdē taṁde paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="36">
