      <lg n="76">
	<l>esevī paṁcākṣarīmaṁtrame gurutaramaṁtraṁ viśuddhāṁgalēpaṁ</l>
	<l>bhasitaṁ rudrākṣiyē bhūṣaṇatati paramasvāmi nīṁ pūjyanānaṁ</l>
	<l>dasamētaṁ bhaktanē sat‌kulajanenisidaṁ naṁbi mattēnuvaṁ bhā</l>
	<l>visadirpaṁtittu paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="77">
	<l>karevalliṁ munnavō ō magane magane baṁdeṁ diṭaṁ baṁdeneṁdā</l>
	<l>daradiṁdaṁ nīne baṁdenna vayavananitaṁ muṭṭenoṁdā baḷaldā</l>
	<l>karedā kaṁdā enuttuṁ kr̥pe mige nalaviṁ nōḍi muṁḍāḍuteṁduṁ</l>
	<l>siradoḷ kaiyikki paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="78">
	<l>nimagennaṁ māṟugoṭṭiṁ purahara nimagennaṁ sadā toḷtugoṭṭeṁ</l>
	<l>nimagennaṁ sūṟegoṭṭeṁ nimage haruṣadiṁdoccataṁ koṭṭenāhā</l>
	<l>nimagennaṁ maccugoṭṭeṁ guruve ghanave saṁtōṣadiṁdoppugoṭṭeṁ</l>
	<l>nimagennaṁ dēva paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="79">
	<l>mudadiṁdaṁ kāmamaṁ kōpamanuṟe jaṟedā mōhamaṁ dāṁṭi lōbha</l>
	<l>tvada bēraṁ kiḷtu mātsaryamanuḍugi madālēpamaṁ tīrciyāśā</l>
	<l>sadanakkāsattu bēsatta tuḷaśivasukhāvāsadoḷ bhaktiyiṁ tvat</l>
	<l>padamaṁ sārvaṁte paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="80">
	<l>enagār daivaṁ virūpākṣane guruvenagāvaṁ virūpākṣanē kēḷ</l>
	<l>janakaṁ tānār virūpākṣane jananiyadāvaḷ virūpākṣanē ā</l>
	<l>ḷdanadāvaṁ śrīvirūpākṣane nijasakhanāvaṁ virūpākṣanē eṁ</l>
	<l>binitaṁ saitittu paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="81">
	<l>manedaivaṁ mukhyadaivaṁ sukhatarakuladaivaṁ parānaṁdadaivaṁ</l>
	<l>manadoḷ naṭṭirpa daivaṁ śaraṇajanamahōtsāhadaivaṁ karaṁ peṁ</l>
	<l>pina daivaṁ daivadaivaṁ sakalasukr̥tadaivaṁ sudhākāradaivaṁ</l>
	<l>ghanadaivaṁ nīne paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="82">
	<l>paramārthaṁ nimma sammak parataranijamaṁ bhāvisal baṇṇisal tā</l>
	<l>marasōdbhūtaṁge śakraṁgasuraripuge vēdakatarkyaṁ daleṁdaṁ</l>
	<l>dorevaṁtāṁ martyaneṁbī vacaname parihāsāspadaṁ dēva nīnē</l>
	<l>karuṇaṁgeyyutte paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="83">
	<l>bisavaṁ tāḷdirdu nityaṁ smarananuripiyuṁ kāmi sarvēśvaraṁ ma</l>
	<l>ttasamaṁ bhikṣēśvaraṁ sarvamanaḷidanaghaṁ caṁdranaṁ sūḍiyuṁ kō</l>
	<l>pasamāyuktaṁ viruddhaprakr̥ti tiḷiyadārgaṁ kr̥pāvārdhi ninnaṁ</l>
	<l>ghrisarōjaṁdōṟi paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="84">
	<l>sthiravallaṁ nōḍe sargasthitilayamayavāgirpudiṁtī prapaṁcaṁ</l>
	<l>sthirarūpaṁ nīne karmadvitayavirahitaṁ nīne śuddhātmakaṁ nī</l>
	<l>ne rasādivyōmadik‌pūrita nijanidhi nīneṁbabhijñānamaṁ mad</l>
	<l>guruvē nīnittu paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="85">
	<l>aparicchinnaṁ svataṁtraṁ niravadhiyamaḷaṁ śaṁkaraṁ nityanānaṁ</l>
	<l>dapadaṁ śāṁtārkakōṭiprabhanajaranaciṁtyaṁ paraṁdhāmarūpaṁ</l>
	<l>vipuḷajñānābdhi satyaṁ nirupamanidhi nīneṁbabhijñānamaṁ nīṁ</l>
	<l>kr̥peyaṁ māḍutte paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="86">
	<l>sthūlaṁ sūkṣmaṁ susūkṣmaṁ sulabhanasulabhaṁ puṇyapāpapradūraṁ</l>
	<l>nīlagrīvaṁ cidātmaṁ bhavanabhavananūnādyanādyaṁtaśūnyaṁ</l>
	<l>kālaghnaṁ kālarūpaṁ natanikaravipajjālavicchēdalīlā</l>
	<l>lōlaṁ nīṁ nīne paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="87">
	<l>śiva sarvādhāra gaṁgādhara purahara sarvajña sarvēśa gaurī</l>
	<l>dhava nīlagrīva kālāṁtaka paśupati phālākṣa bhōgīṁdrabhūṣā</l>
	<l>bhava rudrēśāna bharga pramathanidhi mahādēva mārāri nityō</l>
	<l>tsava satyaprēmi paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="88">
	<l>giriśa śrīkaṁṭha dakṣādhvarahara vr̥ṣabhārūḍha kāpāliyaṁdhā</l>
	<l>suravairi vyōmakēśa kratukulanr̥pati sthāṇu bhūtēśa paṁcā</l>
	<l>varaṇapratyakṣa paṁcānana mr̥ḍa gajacarmāṁbaraśrēṣṭha viśvō</l>
	<l>dara sadyōjāta paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="89">
	<l>hara bhīma tryakṣa bhakta vrajahr̥daya pināki triśūli trikālā</l>
	<l>kṣara nirdēhābhavā dhūrjaṭi jaṭilaśirōmāli śaṁbhu prapaṁcō</l>
	<l>ttara paṁcabrahma paṁcādhika himakara cūḍāmaṇī vīrabhadrē</l>
	<l>śvara kālātīta paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="90">
	<l>varakāruṇyābdhi ṣaḍ‌darśanahita paramasvāmi sarvajña paṁcā</l>
	<l>kṣaragarbhāvāsa mādyat‌pramathajanaparītōṣa viśvēśa tattvā</l>
	<l>kara tārādrīśa nārāyaṇanayanalasat‌pāda nādātma bhaktā</l>
	<l>turacitta grāhi paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="91">
	<l>śiva nimmiṁ puṭṭitī māye gaḍenipidanāṁ sairiseṁ puṭṭateṁboṁ</l>
	<l>davicāraṁ niṣ‌kriyātmaprabhutanake karaṁ hāni śuddhātmanoḷ śaṁ</l>
	<l>bhuvinoḷ samyak‌parānaṁdada tavanidhiyoḷ ninnoḷī bhrāṁtiyeṁbā</l>
	<l>śraveyaṁ targotti paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="92">
	<l>modaliṁdaṁ kūrmarōmaṁ bageye śaśiviṣāṇaṁ viyat‌puṣpadaṁti</l>
	<l>lladudē satyaṁ prapaṁceṁdaṟidu tiḷidu niṣkāma nirmāya nityā</l>
	<l>bhyudayānaṁdaikatējōnidhi nirupama nirlēpa nirvāṇa nīneṁ</l>
	<l>bidanē saitittu paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="93">
	<l>tōṟuttirpī jagaṁ tānaṟivina mukhadoḷ tōṟadirpaṁte tōrkuṁ</l>
	<l>tōṟal pēḷalke kēḷalkasadaḷamenipā brahmatābrahmavāgu</l>
	<l>ttāṟuṁ baṇṇakkamēḷuṁ tanuvina poregeṁṭuṁ śarīrakke mikkuṁ</l>
	<l>mīṟirpaṁtittu paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="94">
	<l>toḷaguttirparkaniṁdāgasavenitanitaṁ māḍidaṁtirpa dhātrī</l>
	<l>taḷamellaṁ caṁdraniṁdaṁ samedudenisidaṁtirpa dik‌saṁkuḷaṁ ni</l>
	<l>rmaḷavidyullēkheyiṁ nirmisidavolesedirpā paraṁjyōtiyennoḷ</l>
	<l>beḷaguttirpaṁte paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="95">
	<l>guruviṁ śuddhātmanādeṁ guruvina kr̥peyiṁdaṁ jagatpūjyanādeṁ</l>
	<l>guruviṁ niṣkāmanādeṁ ghanataraguruviṁ śāṁtisaṁpannanādeṁ</l>
	<l>guruviṁ sarvajñanādeṁ diṭavenisidanennoḷ diṭaṁ māḍutuṁ mad</l>
	<l>guruvē gaurīśa paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="96">
	<l>ennānaṁdābdhiyē ennanupamasudheyē enna puṇyasvarūpē</l>
	<l>ennāyuḥpuṁjavē ennaye gatimatiyē enna vijñānamūrtī</l>
	<l>ennatyāścaryavē ennatiśayaguruvē enna caitanyadāgē</l>
	<l>enna prāṇēśa paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="97">
	<l>nityajñānaikamūrtī sukhataraparamānaṁda sarvajñamūrtī</l>
	<l>nityatvādhāramūrtī niravayavamahāmūrti nirlēpamūrtī</l>
	<l>nityapratyakṣamūrtī nikhilaguṇagaṇādhāra nirmāyamūrtī</l>
	<l>nityaśrīmūrti paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="98">
	<l>biḍenīśā nimma pādābjamanelele biḍeṁ sīḷdoḍaṁ pōḷdoḍaṁ po</l>
	<l>ydoḍamaṁdiṁdeṁdumeṁtuṁ biḍenabhava biḍeṁ śaṁkarā māṇenāṁ bal‌</l>
	<l>viḍideṁ mattattamittaṁ caliyisadele mat‌svāmi nimmājñeyiṁdaṁ</l>
	<l>mr̥ḍanē bhaktārthi paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="99">
	<l>kartāraṁ nīne paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
	<l>bhartāraṁ nīne paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
	<l>hartāraṁ nīne paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
	<l>kūrtiṁtōraṁte paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="100">
	<l>bharadiṁ kēḷdōduvānaṁdadoḷatiśayadiṁ macci lālippavargā</l>
	<l>daradiṁ nityāyuvaṁ saṁpadavanabhavanīyuttu mirkeṁdanūnaṁ</l>
	<l>dhareyoḷ kaikoṁḍu rakṣāśatakavanolaviṁ prēmadiṁ nacci pēḷdaṁ</l>
	<l>haridēvaṁ dēva paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
      <lg n="101">
	<l>piṁdēnēnāgi baṁdeṁ manujajananamuṁ tānideṁtāytu saṁsā</l>
	<l>raṁ dōṣaṁ kāmalōbhādigaḷenagamivelliṁde baṁdattu mattaṁ</l>
	<l>muṁdēnādappeneṁdānaṟiyade bhayadiṁ śaṁkisuttirdapeṁ nīṁ</l>
	<l>saṁdēhaṁ māḍi paṁpāpuradarasa virūpākṣa rakṣippudennaṁ</l>
      </lg>
    </body>
  </text>
