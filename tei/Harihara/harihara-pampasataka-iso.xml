    <body>
      <head>paṁpāśatakaṁ</head>
      <lg n="1" met="śārdūlavikrīḍita">
        <label>śārdūlavikrīḍita</label>
	<l>śrīmad rājakaḷāvataṁsa dhare caṁdrārkāgni jīvānila‌</l>
	<l>vyōmāṁbuprakaraṁgaḷiṁ sakalamaṁ rakṣippa sarvēśa su</l>
	<l>trāmāditridaśavrajārcitapadāṁbhōjāta sadbhaktiyaṁ </l>
	<l>prēmaṁ kaimige māḍu nīnenage paṁpā śrīpurādhīśvarā</l>
      </lg>
      <lg n="2" met="caṁpakamāle">
        <label>caṁpakamāle</label>
	<l>puḷakada hādigeṁdu pathavappudu kaṇgaḷa kōḍigeṁdu nī </l>
	<l>rgaḷa kaḍegāṇbudenna caraṇaṁgaḷa līlegadeṁdu kīlgaḷa </l>
	<l>ccaḷivudu kaiya kaṁpada kadaṁ teṟedappudu tappadī manō </l>
	<l>gaḷitatarābdhigeṁdu mige mēṟeyagalvudu haṁpeyāḷdanē</l>
      </lg>
      <lg n="3" met="caṁpakamāle">
        <label>caṁpakamāle</label>
	<l>puḷakada toṭṭiloḷ bemara majjanadiṁ desaleṇṇe(?)yiṭṭu ka </l>
	<l>ṇgaḷa molevālanūḍi todaḷiṁdave baṇṇisi hāḍi kaṁpadiṁ </l>
	<l>daḷavaḍe tūgiyacca sukhanidreyanaṁdamanuṁṭumāḍi ni </l>
	<l>ścaḷanijabhaktiyittu sale rakṣipudeṁdele haṁpeyāḷdanē</l>
      </lg>
      <lg n="4" met="caṁpakamāle">
        <label>caṁpakamāle</label>
	<l>harahara enna kaiya hasivōḍalaṇaṁ tanuviṁde pūjeyaṁ </l>
	<l>viracipeneṁdo kaṇgaḷa baṟaṁ tiḷiyal posanōṭadiṁde keṁ </l>
	<l>karisuveneṁdo maimaṟedu kaṇgeḍalappi manōnurāgadiṁ </l>
	<l>nerevenadeṁdo nimmanatinēhade pēḷele haṁpeyāḷdanē</l>
      </lg>
      <lg n="5" met="caṁpakamāle">
        <label>caṁpakamāle</label>
	<l>karevudadeṁdu kālviḍisikoḷvudadeṁdu dayākaṭākṣadiṁ </l>
	<l>porevudadeṁdu mel‌nuḍigaḷiṁ madavēṟipudeṁdu sōṁkiniṁ</l>
	<l>dorevudadeṁdu saṁtasade percipudeṁdamardappinoḷ karaṁ </l>
	<l>karagipudennaneṁdosedu nīṁ kr̥peyiṁdele haṁpeyāḷdanē</l>
      </lg>
      <lg n="6" met="caṁpakamāle">
        <label>caṁpakamāle</label>
	<l>teremasagal‌ sukhāśruvidirēṟutiral puḷakaṁ bemar karaṁ </l>
	<l>pariyiḍe gadgadaṁ suḻigoḷuttire kaṁpanamurki līleyo</l>
	<l>ttarisutiral navīnanijabhaktitaraṁgiṇi mīṟutubbaraṁ</l>
	<l>bariyutumenna mēle maḍugaṭṭuvudeṁdele haṁpeyāḷdanē</l>
      </lg>
      <lg n="7" met="mattēbhavikrīḍita">
        <label>mattēbhavikrīḍita</label>
	<l>naḍetaṁdennaye kaṇgaḷalliru virūpākṣā virūpākṣa nīṁ </l>
	<l>biḍadaṁtennaye jihveyalliru virūpākṣā virūpākṣa nīṁ </l>
	<l>eḍegoṁḍennaye cittadalliru virūpākṣā virūpākṣa nīṁ</l>
	<l>iḍidaṁtennoḷe kūḍi nillele virūpākṣā virūpākṣanē</l>
      </lg>
      <lg n="8" met="utpalamāle">
        <label>utpalamāle</label>
	<l>nōḍada kaṇgaḷēke sale kēḷada karṇamadēke bhaktiyiṁ </l>
	<l>pāḍada bāyadēke pesargoḷḷada jihveyadēke pūjeyaṁ </l>
	<l>māḍada kaigaḷēke neṟe sōṁkada dēhamadēke kūḍiya </l>
	<l>ḻkāḍada cittavēkenage haṁpeya liṁgave nimmoḷaḻkaṟiṁ</l>
      </lg>
      <lg n="9" met="śārdūlavikrīḍita">
        <label>śārdūlavikrīḍita</label>
	<l>eṁduṁ nimmoḷelē mahēśane manaṁ baṁdaṁte ciṁtippa kaṇ </l>
	<l>baṁdaṁtīkṣipa jihve baṁda teṟadiṁ baṇṇippa maiyyurbiniṁ </l>
	<l>baṁdaṁtāṁ puḷakippa kaigaḷenituṁ baṁdaṁte pūjippa kāl </l>
	<l>baṁdaṁtāḍuva saipu sārvudenaginneṁdō virūpākṣanē</l>
      </lg>
      <lg n="10" met="mattēbhavikrīḍita">
        <label>mattēbhavikrīḍita</label>
	<l>idu citraṁ varamaṁtra saṁtati virūpākṣaṁ virūpākṣaneṁ </l>
	<l>bude mātakkaṭa tanna jīvame virūpākṣā virūpākṣanā </l>
	<l>madināgaḷ pudidaṁtirirpudumidēnītaṁgenuttellaruṁ</l>
	<l>padedennaṁ nuḍivaṁdadiṁ neneveninneṁdō virūpākṣanē</l>
      </lg>
      <lg n="11" met="mattēbhavikrīḍita">
        <label>mattēbhavikrīḍita</label>
	<l>kramadiṁ pūjipa pūje mellane saḍildānaṁdamaḻkāḍuti</l>
	<l>rkema sōtsāhade kaṇgaḷoḷ sukharasaṁ hastaṁgaḷoḷ kaṁpanaṁ </l>
	<l>kramadoḷ nartanamaṁgadoḷ puḷakamā jihvāgradoḷ lalle saṁ </l>
	<l>bhramadiṁ puṭṭaladeṁdu pūjisuvenāṁ ninnaṁ virūpākṣanē</l>
      </lg>
      <lg n="12" met="mahāsragdhare">
        <label>mahāsragdhare</label>
	<l>satiputrar mitrarāptar tanudhanamanaveṁbiṁtivaṁ nityameṁdu</l>
	<l>nnatara vyāsaṁgadiṁ meyyaṟiyade maruḷāgirdenennaṁ durāśā</l>
	<l>vr̥tanaṁ durmōhiyaṁ dustaratara viṣayavyāptanaṁ durvivēkō </l>
	<l>ditanaṁ durbōdhanaṁ rakṣipudele kr̥peyiṁdaṁ virūpākṣaliṁgā</l>
      </lg>
      <lg n="13" met="caṁpakamāle">
        <label>caṁpakamāle</label>
	<l>anupamadāniyapratimadāni niraṁtaradāni saṁda peṁ </l>
	<l>pina ghanadāni kautukada dāni mahōnnatadāniyeṁdu ni </l>
	<l>nnane pogaḷuttumiṁtide samastajagajjanavī sukīrtige </l>
	<l>nnane naḍe nōḍadirpiravadarkanukūlame haṁpeyāḷdanē</l>
      </lg>
      <lg n="14" met="sragdhare">
        <label>sragdhare</label>
	<l>nānājanmaṁgaḷoḷ bārada paribhavamaṁ baṁda tannaṁdamaṁ tā </l>
	<l>nēneṁdoṁdeḷḷanittaṁ neneyadu tanageṁticcheyaṁtirdu ninnī </l>
	<l>dhyānāraṁbhakkaṇaṁ salladu suḍu suḍu ciḥ manmanōvr̥tti ninnaṁ </l>
	<l>tānāṟeṁ nīne saṁtaṁ nilisidanolaviṁdaṁ virūpākṣaliṁgā</l>
      </lg>
      <lg n="15" met="mahāsragdhare">
        <label>mahāsragdhare</label>
	<l>pasiviṁdaṁ bēṁṭegaṁ naṭṭaḍavige naḍetaṁdēṟi bilvāgramaṁ vyā </l>
	<l>pisadattittaṁ mr̥gadhyānadoḷire śivarātrivrataṁgeydaneṁdaṁ </l>
	<l>dosedā bēḍaṁge sārūpyada ghanapadamaṁ koṭṭoḍaṁ dāniyeṁda </l>
	<l>rcisi ninnaṁ naṁbideṁ rakṣipudele kr̥peyiṁdaṁ virūpākṣanennaṁ</l>
      </lg>
      <lg n="16" met="sragdhare">
        <label>sragdhare</label>
	<l>mōhakkōrorme mātsaryada nuḍinelegōrorme saṁdirda kāmō</l>
	<l>tsāhakkōrorme korvirdodavida madakōrorme percirda lōbha</l>
	<l>vyūhakkōrorme kōpōnnatiya mamategōrorme meyverciniṁ dē</l>
	<l>hōhaṁ eṁdeṁbudaṁ māṇisu manakeyidoṁdaṁ virūpākṣaliṁgā</l>
      </lg>
      <lg n="17" met="caṁpakamāle">
        <label>caṁpakamāle</label>
	<l>madanavirōdhi bāra duritāṁtaka bāra purāri bāra śā </l>
	<l>radaśaśimauḷi bāra phaṇikuṁḍala bāra mahēśa bāra pu </l>
	<l>ṇyada neleverce bāra satataṁ porevāḷdane bāra mēreda </l>
	<l>ppida karuṇābdhi bāra hara bārele bārele haṁpeyāḷdanē</l>
      </lg>
      <lg n="18" met="mattēbhavikrīḍita">
        <label>mattēbhavikrīḍita</label>
	<l>karaṇaṁgaḷ kaḷeyēṟe lōcanayugaṁ nīrēṟe meyyallavaṁ </l>
	<l>kuravēṟal nuḍi kaṁpavēṟe caraṇaṁgaḷ‌ līleyēṟal mogaṁ </l>
	<l>siriyēṟal talegēṟidutsavade nimmaṁ pūjisuttānumā </l>
	<l>daradiṁdīkṣisutāḍutirpudenaginneṁdō virūpākṣanē</l>
      </lg>
      <lg n="19" met="utpalamāle">
        <label>utpalamāle</label>
	<l>keyge namōnamō padedu kaṁpisutīśvara nimma narcipā </l>
	<l>bāyge namōnamō todaḷadunnatabhaktiyoḷeyde pāḍuvā </l>
	<l>meyge namōnanō puḷakamaṁ kelasārcute sōṁki percuvā </l>
	<l>suyge namōnamō biḍada lalleya nēhade haṁpeyāḷdanaṁ</l>
      </lg>
      <lg n="20" met="caṁpakamāle">
        <label>caṁpakamāle</label>
	<l>uḍuvoḍe saṁtataṁ pulidoval nimagalladoḍā digaṁbaraṁ </l>
	<l>paḍuvoḍe rudrabhūmi nimagalladoḍā nigamōttamāṁgamu </l>
	<l>ṇboḍe viṣamalladirdoḍe samastajagaṁ nimagēnaneṁdapar </l>
	<l>tuḍuvoḍe sarpanalladoḍe kuṁjaracarmave haṁpeyāḷdanē</l>
      </lg>
      <lg n="21" met="mahāsragdhare">
        <label>mahāsragdhare</label>
	<l>vinutabrahmāṁḍamaṁ puṭṭipa harahara pālippa sāmarthyareṁdoṁ </l>
	<l>dinisuṁ koṁḍāḍi bhāpeṁdajaharigaḷanāṁ baṇṇisuttirpenē bhōṁ </l>
	<l>kane nimmoṁdājñeyennī manake masakadiṁdaṁdu tōṟalkahō na </l>
	<l>ccina vākyaṁ mudrisal summanirute maṟavaṭṭeṁ virūpākṣaliṁgā</l>
      </lg>
      <lg n="22" met="caṁpakamāle">
        <label>caṁpakamāle</label>
	<l>navanidhi bāra puṇyanidhi bāra mahānidhi bāra bhaktaru</l>
	<l>tsavanidhi bāra bhāgyanidhi bāra sudhārasakāyakāṁtiyu </l>
	<l>dbhavanidhi bāra sattvanidhi bāra kr̥pānidhi bāra satyasaṁ</l>
	<l>bhavanidhi bāra tattvanidhi bārele bārele haṁpeyāḷdanē</l>
      </lg>
      <lg n="23" met="caṁpakamāle">
        <label>caṁpakamāle</label>
	<l>harahara karmadoḷ baḷaladiṁtu barduṁkidenai sadāśivā </l>
	<l>narapara sēveyoḷ kudiyadiṁtu barduṁkidenai makhāriya </l>
	<l>sthiraparadaivadoḷ toḍaradiṁtu barduṁkidenai mahēśa ma </l>
	<l>dguruve purāri pūjyane nijāṁghrige sārcele haṁpeyāḷdanē</l>
      </lg>
      <lg n="24" met="utpalamāle">
        <label>utpalamāle</label>
	<l>dēva mahēśa dēva girijādhipa dēva samastabhaktasaṁ </l>
	<l>jīvana dēva kāmamadamardana dēva hiraṇyagarbhavi </l>
	<l>drāvaṇa dēva viṣṇunayanārcitapādapayōja dēva saṁ </l>
	<l>sēvitadēvadēva mamarakṣaka rakṣisu haṁpeyāḷdanē</l>
      </lg>
      <lg n="25" met="mattēbhavikrīḍita">
        <label>mattēbhavikrīḍita</label>
	<l>puravaṁ suṭṭavanītanītane haribrahmarge sāmarthyadoṁ </l>
	<l>diravaṁ koṭṭavanītanītane mahōgrābhīḷasarpaṁgaḷā </l>
	<l>bharaṇaṁdoṭṭivanītanītane lasacchītāṁśuvaṁ mauḷiyoḷ </l>
	<l>sthiravāgiṭṭavanītanītane virūpākṣaṁ lalāṭēkṣaṇaṁ</l>
      </lg>
      <lg n="26" met="mattēbhavikrīḍita">
        <label>mattēbhavikrīḍita</label>
	<l>paramēśa prabhuvītanītane nijaṁ naṁbirda bhaktarge ta </l>
	<l>nniravaṁ tōṟuvanītanītane jagatsaṁhāravaṁ māḍuvā </l>
	<l>garaḷaṁdāḷdavanītanītane sagarvaṁ perce vāṇīśanā </l>
	<l>siravaṁ kiḷtavanītanītane virūpākṣaṁ lalāṭēkṣaṇaṁ</l>
      </lg>
      <lg n="27" met="mattēbhavikrīḍita">
        <label>mattēbhavikrīḍita</label>
	<l>smaranaṁ nōḍidanītanītane samudyatkōpadiṁ dakṣana </l>
	<l>dhvaramaṁ suṭṭavanītanītane kuṟutteytaṁdu niṁdaṁdhakā </l>
	<l>suranaṁ meṭṭidanītanītane karaṁ baṁdārpiniṁdaṁ gajā </l>
	<l>suranaṁ sīḷdavanītanītane virūpākṣaṁ lalāṭēkṣaṇaṁ</l>
      </lg>
      <lg n="28" met="mattēbhavikrīḍita">
        <label>mattēbhavikrīḍita</label>
	<l>vasudhāvaṁditanītanītane mahānāṭyābhiraṁgaṁ virā </l>
	<l>jise niṁdāḍidanītanītane nitāṁtaṁ bhaktayūthakke saṁ </l>
	<l>tasamaṁ sārcuvanītanītane murāribrahmaroldoldu pū </l>
	<l>jisuvīśaprabhuvītanītane virūpākṣaṁ lalāṭēkṣaṇaṁ</l>
      </lg>
      <lg n="29" met="mattēbhavikrīḍita">
        <label>mattēbhavikrīḍita</label>
	<l>jitapuṣpāyudhanītanītane sarōjātākṣavāṇīśavaṁ </l>
	<l>ditasarvēśvaranītanītane sahasrākṣapramukhyāmarā </l>
	<l>rcitapādāṁbujanītanītane kapāḷābhīḷamāḷāvimaṁ </l>
	<l>ḍitavakṣaḥsthaḷanītanītane virūpākṣaṁ lalāṭīkṣaṇaṁ</l>
      </lg>
      <lg n="30" met="mattēbhavikrīḍita">
        <label>mattēbhavikrīḍita</label>
	<l>natadēvādhipanītanītane viriṁcōpēṁdramadhyasthitō </l>
	<l>ddhataliṁgōdbhavanītanītane sahasrāṁśupramukhyarkaḷu </l>
	<l>nnatatējōnidhiyītanītane paraṁjyōtissvarūpaprakā </l>
	<l>śitapuṇyōdayanītanītane virūpākṣaṁ lalāṭēkṣaṇaṁ</l>
      </lg>
      <lg n="31" met="mattēbhavikrīḍita">
        <label>mattēbhavikrīḍita</label>
	<l>trijagat‌pūjitanītanītane surar koṁḍāḍe divyāstramaṁ </l>
	<l>vijayaṁgittavanītanītane manaṁ muṭṭirpa niṣkāmabha </l>
	<l>ktajanakkāśrayanītanītane lasat‌sāmarthyadiṁdaṁ śirō </l>
	<l>vrajamaṁ tāḷdavanītanītane virūpākṣaṁ lalāṭēkṣaṇaṁ</l>
      </lg>
      <lg n="32" met="śārdūlavikrīḍita">
        <label>śārdūlavikrīḍita</label>
	<l>vēdakkunnatanītanītane haribrahmādigaḷ māḷpa saṁ </l>
	<l>vādakkaggaḷanītanītane śaraṇ‌bokkirda bhaktāḷiyaṁ </l>
	<l>kāduṁ rakṣipanītanītane gaṇavrātakke tāy taṁde tā </l>
	<l>nādā śaṁkaranītanītane virūpākṣaṁ lalāṭēkṣaṇaṁ</l>
      </lg>
      <lg n="33" met="śārdūlavikrīḍita">
        <label>śārdūlavikrīḍita</label>
	<l>śrīgaṁgādharanaṁ śaśāṁkaśikhimārtaṁḍatriṇētrāṁkanaṁ </l>
	<l>bhōgīṁdrārcitanaṁ ratīśavipinaprōd‌bhūtadāvāgniyaṁ </l>
	<l>yōgivrātaparītanaṁ śaraṇahr̥d‌rājīvasaptāśvanaṁ</l>
